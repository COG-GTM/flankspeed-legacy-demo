@model WorkItem
@{
    ViewData["Title"] = "Edit — " + Model.Title;
    var categories = (List<Category>)ViewBag.Categories;
    var isDraft = Model.Status?.Name == "Draft";
}

<!-- MIGRATION NOTE [PowerApp]: Read-only conditional fields map to Power Fx DisplayMode. Example: If(ThisItem.Status = "Draft", DisplayMode.Edit, DisplayMode.View) -->

<h2>Edit CWA Request</h2>
<a href="/Cwa/Details/@Model.Id" class="btn btn-default btn-sm">&laquo; Back to Details</a>
<hr />

<form method="post" action="/Cwa/Edit/@Model.Id">
    @Html.AntiForgeryToken()

    <fieldset>
        <legend>Basic Information</legend>

        <div class="form-group">
            <label for="Title">Title</label>
            <input type="text" id="Title" name="Title" class="form-control" value="@Model.Title" required @(isDraft ? "" : "disabled") />
            @if (!isDraft)
            {
                <input type="hidden" name="Title" value="@Model.Title" />
            }
        </div>

        <div class="form-group">
            <label for="Description">Description</label>
            <textarea id="Description" name="Description" class="form-control" rows="4">@Model.Description</textarea>
        </div>

        <div class="form-group">
            <label for="CategoryId">Category</label>
            <select id="CategoryId" name="CategoryId" class="form-control" @(isDraft ? "" : "disabled")>
                @foreach (var c in categories)
                {
                    <option value="@c.Id" selected="@(c.Id == Model.CategoryId ? "selected" : null)">@c.Name</option>
                }
            </select>
            @if (!isDraft)
            {
                <input type="hidden" name="CategoryId" value="@Model.CategoryId" />
            }
        </div>

        <div class="form-group">
            <label for="Priority">Priority</label>
            <select id="Priority" name="Priority" class="form-control">
                <option value="Low" selected="@(Model.Priority == "Low" ? "selected" : null)">Low</option>
                <option value="Medium" selected="@(Model.Priority == "Medium" ? "selected" : null)">Medium</option>
                <option value="High" selected="@(Model.Priority == "High" ? "selected" : null)">High</option>
                <option value="Critical" selected="@(Model.Priority == "Critical" ? "selected" : null)">Critical</option>
            </select>
        </div>

        <div class="form-group">
            <label for="DueDate">Due Date</label>
            <input type="date" id="DueDate" name="DueDate" class="form-control" value="@Model.DueDate?.ToString("yyyy-MM-dd")" />
        </div>
    </fieldset>

    <fieldset id="justification-section" style="display: none;">
        <legend>Justification (Required for Critical Priority)</legend>
        <div class="form-group">
            <label for="Justification">Justification</label>
            <textarea id="Justification" name="Justification" class="form-control" rows="3">@Model.Justification</textarea>
        </div>
    </fieldset>

    <fieldset id="facility-section" style="display: none;">
        <legend>Facility Access Details</legend>
        <div class="form-group">
            <label for="BuildingNumber">Building Number</label>
            <input type="text" id="BuildingNumber" name="BuildingNumber" class="form-control" value="@Model.BuildingNumber" />
        </div>
        <div class="form-group">
            <label for="AccessLevel">Access Level</label>
            <select id="AccessLevel" name="AccessLevel" class="form-control">
                <option value="">Select...</option>
                <option value="General" selected="@(Model.AccessLevel == "General" ? "selected" : null)">General</option>
                <option value="Restricted" selected="@(Model.AccessLevel == "Restricted" ? "selected" : null)">Restricted</option>
                <option value="Confidential" selected="@(Model.AccessLevel == "Confidential" ? "selected" : null)">Confidential</option>
                <option value="Top Secret" selected="@(Model.AccessLevel == "Top Secret" ? "selected" : null)">Top Secret</option>
            </select>
        </div>
    </fieldset>

    <button type="submit" class="btn btn-primary">Save Changes</button>
    <a href="/Cwa/Details/@Model.Id" class="btn btn-default">Cancel</a>
</form>

@section Scripts {
    <script src="~/js/cwa-form.js"></script>
}
