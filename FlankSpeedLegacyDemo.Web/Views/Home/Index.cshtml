@{
    ViewData["Title"] = "Dashboard";
    var obsStatusCounts = (Dictionary<string, int>)ViewBag.ObsStatusCounts;
    var cwaStatusCounts = (Dictionary<string, int>)ViewBag.CwaStatusCounts;
    var myItems = (List<WorkItem>)ViewBag.MyItems;
    var recentActivity = (List<AuditLog>)ViewBag.RecentActivity;
}

<!-- MIGRATION NOTE: This home dashboard would be replaced by a Viva Connections dashboard or a SharePoint home page with SPFx web parts -->

<h2>Ops Tracker &mdash; Operations Management Dashboard</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <div class="panel panel-default">
            <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
                <h3 class="panel-title">OBS Module Summary <small style="color: #cccccc;">(@ViewBag.TotalObs total records)</small></h3>
            </div>
            <div class="panel-body">
                <table class="table table-striped table-bordered table-condensed">
                    <thead>
                        <tr><th>Status</th><th>Count</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var kvp in obsStatusCounts)
                        {
                            <tr><td>@kvp.Key</td><td>@kvp.Value</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="panel panel-default">
            <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
                <h3 class="panel-title">CWA Module Summary <small style="color: #cccccc;">(@ViewBag.TotalCwa total requests)</small></h3>
            </div>
            <div class="panel-body">
                <table class="table table-striped table-bordered table-condensed">
                    <thead>
                        <tr><th>Status</th><th>Count</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var kvp in cwaStatusCounts)
                        {
                            <tr><td>@kvp.Key</td><td>@kvp.Value</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
        <h3 class="panel-title">My Assigned Items</h3>
    </div>
    <div class="panel-body">
        @if (myItems.Any())
        {
            <table class="table table-striped table-bordered">
                <thead>
                    <tr><th>ID</th><th>Module</th><th>Title</th><th>Status</th><th>Priority</th><th>Due Date</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in myItems)
                    {
                        var detailUrl = item.Module == "OBS" ? $"/Obs/Details/{item.Id}" : $"/Cwa/Details/{item.Id}";
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Module</td>
                            <td><a href="@detailUrl">@item.Title</a></td>
                            <td>@item.Status?.Name</td>
                            <td>@item.Priority</td>
                            <td>@item.DueDate?.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No items currently assigned to you.</p>
        }
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
        <h3 class="panel-title">Recent Activity</h3>
    </div>
    <div class="panel-body">
        <table class="table table-striped table-bordered table-condensed">
            <thead>
                <tr><th>Date</th><th>Action</th><th>Work Item</th><th>By</th><th>Details</th></tr>
            </thead>
            <tbody>
                @foreach (var log in recentActivity)
                {
                    <tr>
                        <td>@log.Timestamp.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@log.Action</td>
                        <td>@log.WorkItem?.Title</td>
                        <td>@log.PerformedByUser?.DisplayName</td>
                        <td>
                            @if (!string.IsNullOrEmpty(log.OldValue))
                            {
                                <text>@log.OldValue &rarr; </text>
                            }
                            @log.NewValue
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
