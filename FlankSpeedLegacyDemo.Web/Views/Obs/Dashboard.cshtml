@{
    ViewData["Title"] = "OBS Dashboard";
    var countByStatus = (Dictionary<string, int>)ViewBag.CountByStatus;
    var countByPriority = (Dictionary<string, int>)ViewBag.CountByPriority;
    var countByTeam = (Dictionary<string, int>)ViewBag.CountByTeam;
    var myItems = (List<WorkItem>)ViewBag.MyItems;
    var overdueItems = (List<WorkItem>)ViewBag.OverdueItems;
}

<!-- MIGRATION NOTE [SPFx]: This dashboard maps to an SPFx dashboard web part. Summary counts map to Power Fx CountRows(Filter(...)) expressions. -->

<h2>OBS &mdash; Dashboard</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
                <h3 class="panel-title">Count by Status</h3>
            </div>
            <div class="panel-body">
                <table class="table table-condensed table-bordered">
                    @foreach (var kvp in countByStatus)
                    {
                        <tr><td>@kvp.Key</td><td><strong>@kvp.Value</strong></td></tr>
                    }
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
                <h3 class="panel-title">Count by Priority</h3>
            </div>
            <div class="panel-body">
                <table class="table table-condensed table-bordered">
                    @foreach (var kvp in countByPriority)
                    {
                        <tr><td>@kvp.Key</td><td><strong>@kvp.Value</strong></td></tr>
                    }
                </table>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel panel-default">
            <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
                <h3 class="panel-title">Count by Team</h3>
            </div>
            <div class="panel-body">
                <table class="table table-condensed table-bordered">
                    @foreach (var kvp in countByTeam)
                    {
                        <tr><td>@kvp.Key</td><td><strong>@kvp.Value</strong></td></tr>
                    }
                </table>
            </div>
        </div>
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-heading" style="background-color: #003366; color: #ffffff;">
        <h3 class="panel-title">My Assigned Items</h3>
    </div>
    <div class="panel-body">
        @if (myItems.Any())
        {
            <table class="table table-striped table-bordered">
                <thead>
                    <tr><th>ID</th><th>Title</th><th>Status</th><th>Priority</th><th>Due Date</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in myItems)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td><a href="/Obs/Details/@item.Id">@item.Title</a></td>
                            <td>@item.Status?.Name</td>
                            <td>@item.Priority</td>
                            <td>@item.DueDate?.ToString("yyyy-MM-dd")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No items assigned to you.</p>
        }
    </div>
</div>

<div class="panel panel-default">
    <div class="panel-heading" style="background-color: #993333; color: #ffffff;">
        <h3 class="panel-title">Overdue Items</h3>
    </div>
    <div class="panel-body">
        @if (overdueItems.Any())
        {
            <table class="table table-striped table-bordered">
                <thead>
                    <tr><th>ID</th><th>Title</th><th>Status</th><th>Due Date</th><th>Assigned To</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in overdueItems)
                    {
                        <tr class="danger">
                            <td>@item.Id</td>
                            <td><a href="/Obs/Details/@item.Id">@item.Title</a></td>
                            <td>@item.Status?.Name</td>
                            <td>@item.DueDate?.ToString("yyyy-MM-dd")</td>
                            <td>@(item.AssignedToUser?.DisplayName ?? "Unassigned")</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No overdue items.</p>
        }
    </div>
</div>
